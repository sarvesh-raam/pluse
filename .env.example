# --- App ---
APP_NAME=Pulse
ENV=development

# --- Postgres (used by the postgres service itself) ---
POSTGRES_USER=pulse
POSTGRES_PASSWORD=pulse
POSTGRES_DB=pulse
POSTGRES_PORT=5432

# --- Backend (api / scheduler / worker) ---
# Host-relative URL for the api/scheduler/worker containers (talks to the "postgres" service by name)
DATABASE_URL=postgresql+asyncpg://pulse:pulse@postgres:5432/pulse

JWT_SECRET=dev-only-please-change-this-secret-before-any-real-deployment
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

CORS_ORIGINS=["http://localhost:5173"]

HEARTBEAT_SEC=5
VISIBILITY_TIMEOUT_SEC=30
SCHED_TICK_SEC=1
REAPER_TICK_SEC=5

# --- Worker ---
# WORKER_QUEUES empty = subscribe to every queue in WORKER_PROJECT_SLUG's project.
# Scale with `docker compose up --scale worker=3` to see distributed claiming.
WORKER_PROJECT_SLUG=demo
WORKER_QUEUES=
WORKER_CONCURRENCY=5

API_PORT=8000
FRONTEND_PORT=5173

# --- Bonus: AI failure summaries (optional) ---
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
